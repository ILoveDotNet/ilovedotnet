            </ul>

            <CountDemo></CountDemo>
        </DemoSnippet>

        <h4 id="min">Min()</h4>
        
        <p>
            The <Highlight>Min()</Highlight> function return the minimum value from a collection of numbers. For example, you can use Min to find the smallest number in 
            a list of prices.
        </p>

        <CodeSnippet CssClass="language-csharp">
IEnumerable&lt;Product&gt; products = GetProducts();

//Method Syntax
int result = products
             .Select(product =&gt; product.Price)
             .Min();

// OR

int result = products.Min(product =&gt; product.Price);


//Query Syntax
int result = (from product in products
              select product.Price)
             .Min();
             
// OR
 
int result = (from product in products select product).Min(product.Price);
        </CodeSnippet>

