                <li>Click on Intersect Button to view the result</li>
                <li>Click on reset to try other combination</li>
            </ol>

            <IntersectDemo></IntersectDemo>
        </DemoSnippet>

        

        <h3 id="objects">Using LINQ Intersect to compare objects</h3>

        <p>
            Intersect checks for reference equality of two objects for <ContentHighlight>object</ContentHighlight> data types.
        </p>

        <CodeSnippet CssClass="language-csharp">
List&lt;Product&gt; products = GetProducts();
List&lt;Sale&gt; sales = GetSales();

//Method Syntax
List&lt;int&gt; result = products.Select(product =&gt; product.Id)
                   .Intersect(sales.Select(sale =&gt; sale.ProductId))
                   .ToList();
                    
//Query Syntax
List&lt;int&gt; result = (from product in products select product.Id)
                   .Intersect(from sale in sales select sale.ProductId)
                   .ToList();
        </CodeSnippet>

