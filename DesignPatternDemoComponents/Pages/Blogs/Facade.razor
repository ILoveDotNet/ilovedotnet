    Use Entertainment System via Facade
&lt;/button&gt;

@@code {
    private EntertainmentFacade entertainmentFacade = new EntertainmentFacade();

    private string? _result;

    private void HandleFacade()
    {
        // Turn on the entire entertainment system
        entertainmentFacade.TurnOnEntertainmentSystem();
        _result = "Starting the system...";

        // Simulate some movie-watching...
        _result = "Streaming the movie...";

        // Turn off the entire entertainment system
        entertainmentFacade.TurnOffEntertainmentSystem();
